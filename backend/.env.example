# ─── Database Configuration ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5434
# Use strong, unique credentials in every environment (do NOT ship postgres/postgres).
DB_USER=postgres
DB_PASSWORD=change-me-strong-db-password
DB_NAME=obertrack
# Use 'require' (or stronger) in production so the DB connection is encrypted.
DB_SSL_MODE=disable

# ─── Server Configuration ────────────────────────────────────────────────────
# JWT_SECRET MUST be >= 32 bytes and unique per environment. The server refuses
# to start otherwise. Generate one with: openssl rand -base64 48
JWT_SECRET=
SERVER_PORT=8080

# Set to "release" in production. This also disables the /seed bootstrap routes.
GIN_MODE=release

# ─── CORS / Proxy ────────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins (no wildcard).
CORS_ALLOWED_ORIGINS=https://obertrack.com,https://app.obertrack.com
# CIDR(s) of trusted reverse proxies (e.g. the Docker network / load balancer).
TRUSTED_PROXIES=172.16.0.0/12

# ─── Bootstrap / Webhook secrets ─────────────────────────────────────────────
# Secret required to call the /api/seed/* bootstrap endpoints (header X-Seed-Token).
# Leave empty in production to keep them disabled. Generate: openssl rand -hex 32
SEED_BOOTSTRAP_TOKEN=
# Shared secret for Brevo webhooks (header X-Webhook-Token).
BREVO_WEBHOOK_TOKEN=
# Shared HMAC-SHA512 secret configured in WAHA (header X-Webhook-Hmac).
WAHA_WEBHOOK_HMAC=

# ─── Deployment URLs ─────────────────────────────────────────────────────────
SERVICE_URL_BACKEND=http://localhost:8080
SERVICE_FQDN_BACKEND=localhost
SERVICE_URL_FRONTEND=http://localhost:5173
SERVICE_FQDN_FRONTEND=localhost

# ─── Brevo (Sendinblue) Email Service ───────────────────────────────────────
# Get your API key at: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_NAME=Obertrack
BREVO_SENDER_EMAIL=noreply@yourdomain.com

# ─── WAHA (WhatsApp HTTP API) Configuration ──────────────────────────────────
# Public or private URL of your self-hosted WAHA server
WAHA_API_URL=http://localhost:3000
# API key security token of your WAHA (leave empty if no authentication is set)
WAHA_API_KEY=
# Session name on your WAHA server (defaults to 'default')
WAHA_SESSION=default
