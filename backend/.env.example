# ─── Database Configuration ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=obertrack
DB_SSL_MODE=disable

# ─── Server Configuration ────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
SERVER_PORT=8080

# ─── Deployment URLs ─────────────────────────────────────────────────────────
SERVICE_URL_BACKEND=http://localhost:8080
SERVICE_FQDN_BACKEND=localhost
SERVICE_URL_FRONTEND=http://localhost:5173
SERVICE_FQDN_FRONTEND=localhost

# ─── Brevo (Sendinblue) Email Service ───────────────────────────────────────
# Get your API key at: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_NAME=Obertrack
BREVO_SENDER_EMAIL=noreply@yourdomain.com

# ─── WAHA (WhatsApp HTTP API) Configuration ──────────────────────────────────
# Public or private URL of your self-hosted WAHA server
WAHA_API_URL=http://localhost:3000
# API key security token of your WAHA (leave empty if no authentication is set)
WAHA_API_KEY=
# Session name on your WAHA server (defaults to 'default')
WAHA_SESSION=default
