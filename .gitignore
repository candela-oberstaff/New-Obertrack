# .gitignore for Obertrack (Go + React)

# Dependency directories
node_modules/
**/node_modules/
frontend/node_modules/

# Build artifacts
dist/
**/dist/
frontend/dist/
build/
**/build/
backend/bin/
*.exe
*.exe~
*.test
*.prof
*.dll
*.so
*.dylib
frontend/tsconfig.tsbuildinfo

# Environment files
.env
.env.local
.env.*.local
backend/.env

# OS-specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
backend/*.log
logs/
**/logs/

# TypeScript
*.tsbuildinfo
*.tsbuildinfo

# Go test cache
*.out
coverage.txt

# Vite
vite.config.ts.timestamp-*

# Cache
.cache/
**/.cache/
.parcel-cache/

# Project specific
backend/credentials.json
backend/scratch/
backend/test_db2.go
backend/test_db_create.go
backend/build_err.txt
backend/test_*.go
backend/uploads/

# Scratch / debug artifacts (should never be committed)
backend/all_changes.txt
backend/matches.txt
backend/temp_ticket*.json
frontend/build_output.txt
