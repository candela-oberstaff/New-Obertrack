# .gitignore for Obertrack (Go + React)

# Dependency directories
node_modules/
frontend/node_modules/
backend/vendor/

# Build artifacts
dist/
frontend/dist/
backend/bin/
*.exe
*.test
*.prof
frontend/tsconfig.tsbuildinfo

# Environment files
.env
.env.local
.env.*.local
backend/.env

# OS-specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
backend/*.log

# Vite
vite.config.ts.timestamp-*
